---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import phsLogo from '../../assets/images/logotipo-phs-EN-BLANCO.png';

const base = import.meta.env.BASE_URL || '';
const homeUrl = `${base.endsWith('/') ? base.slice(0, -1) : base}/ags/`;
---

<Layout title="¡Gracias! | PHS">
  <div class="min-h-screen flex flex-col bg-dark">
    <div class="flex-grow flex flex-col items-center justify-center px-6 text-center">
      <a href={homeUrl} class="mb-12 hover:scale-105 transition-transform">
        <img src={phsLogo.src} alt="PHS Logistics" class="h-16 md:h-20 w-auto object-contain opacity-90" />
      </a>
      <div class="bg-darkLight p-10 rounded-2xl shadow-2xl border border-white/5 max-w-lg w-full">
        <svg class="w-20 h-20 text-green-500 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h1 class="text-3xl md:text-4xl font-extrabold text-white mb-4">¡Gracias!</h1>
        <p class="text-gray-300 font-body mb-8 text-lg">Tu mensaje ha sido enviado con éxito. Nos pondremos en contacto contigo a la brevedad.</p>
        <a href={homeUrl} class="inline-block px-8 py-3 bg-primary text-white font-bold uppercase tracking-wide rounded-lg transition-all hover:bg-white hover:text-dark">
          Volver al Inicio
        </a>
      </div>
    </div>
    <Footer />
  </div>
</Layout>
