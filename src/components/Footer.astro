---
import phsLogo from '../assets/images/logotipo-phs-EN-BLANCO.png';
---

<footer class="bg-dark text-gray-400 py-12 border-t border-white/10 mt-auto relative z-10">
  <div class="container mx-auto px-6 flex flex-col md:flex-row items-center justify-between">
    <div class="mb-4 md:mb-0 grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
      <img src={phsLogo.src} alt="PHS Logistics" class="h-10 w-auto object-contain" />
    </div>
    <div class="text-sm font-body">
      &copy; 2026 Todos Los Derechos Reservados.
    </div>
  </div>

  <!-- Chatbot Script -->
  <script src="https://conversia.com.mx/assets/js/chatbot.js" id="chatbot-js"></script>
  <!-- Limpiar CSS del chatbot -->
  <link rel="stylesheet" href="chatbot-clean.css\" />

  <script is:inline>
    // Destruir el CSS problemático sin importar cómo y cuándo se inyecte
    const watcher = new MutationObserver(() => {
      document.querySelectorAll('link[href*="chatbot.css"]').forEach((link) => {
        // Permitir solo nuestra versión local limpia
        if (!link.href.includes("/chatbot-clean.css")) {
          link.disabled = true;
          link.remove();
        }
      });
    });
    watcher.observe(document.documentElement, {
      childList: true,
      subtree: true,
    });

    CHATKODEX.init({
      host: window.location.host,
      key: "JOx8h9PQdIb2S",
    });
  </script>
</footer>
