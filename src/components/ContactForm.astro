---
import formBg from '../assets/images/exterior_7.jpeg';
---

<section id="contact" class="min-h-screen relative flex items-center justify-center py-24 overflow-hidden">
  <!-- Immersive Background -->
  <div class="absolute inset-0 z-0">
    <img src={formBg.src} alt="Exterior Park" class="w-full h-full object-cover gs-form-bg" />
    <div class="absolute inset-0 bg-dark/70"></div>
  </div>

  <div class="container relative z-10 mx-auto px-6 max-w-4xl">
    <div class="text-center mb-12 gs-form-title">
      <h2 class="text-4xl md:text-5xl font-extrabold text-primary mb-4">Optimize your transit times</h2>
      <p class="text-xl text-white font-light">Let's discuss how we can reduce your operating costs.</p>
    </div>

    <!-- Glassmorphism Card -->
    <div class="bg-black/20 backdrop-blur-md border border-white/20 shadow-xl rounded-2xl mx-auto p-8 md:p-12 gs-form-card">
      <form id="contactForm" class="flex flex-col gap-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col">
            <label for="nombre" class="text-white text-sm font-medium mb-2">Full name</label>
            <input type="text" id="nombre" name="nombre" class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-primary focus:bg-white/20 transition-all font-body" placeholder="John Doe" required>
          </div>
          
          <div class="flex flex-col">
            <label for="telefono" class="text-white text-sm font-medium mb-2">Phone</label>
            <input type="tel" id="telefono" name="telefono" class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-primary focus:bg-white/20 transition-all font-body" placeholder="(555) 000-0000" required>
          </div>
        </div>
        
        <div class="flex flex-col">
          <label for="correo" class="text-white text-sm font-medium mb-2">Email</label>
          <input type="email" id="correo" name="correo" class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-primary focus:bg-white/20 transition-all font-body" placeholder="john@example.com" required>
        </div>
        
        <div class="flex flex-col">
          <label for="mensaje" class="text-white text-sm font-medium mb-2">Message</label>
          <textarea id="mensaje" name="mensaje" rows="4" class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-white/50 focus:outline-none focus:ring-2 focus:ring-primary focus:bg-white/20 transition-all font-body resize-y" placeholder="Tell us about your project..." required></textarea>
        </div>
        
        <button type="submit" class="mt-4 px-8 py-4 bg-primary text-dark font-bold text-lg rounded-xl uppercase tracking-wider hover:bg-white hover:text-dark transition-all duration-300 shadow-lg hover:shadow-primary/50 transform hover:-translate-y-1">
          <span id="btnText">Send Message</span>
        </button>
        
        <div id="formMessage" class="hidden mt-4 p-4 rounded-xl text-center font-medium font-body transition-all"></div>
      </form>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Form Logic
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const btnText = document.getElementById('btnText');
  const formMessage = document.getElementById('formMessage');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (!btnText || !formMessage) return;
      
      const formData = new FormData(form);
      const data = {
        nombre: formData.get('nombre'),
        telefono: formData.get('telefono'),
        correo: formData.get('correo'),
        mensaje: formData.get('mensaje')
      };

      try {
        btnText.textContent = 'Enviando...';
        const response = await fetch('https://n8n.ongoing.mx/webhook-test/c858672b-7cff-40e0-bc29-f03b41febad7', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        formMessage.classList.remove('hidden', 'bg-red-500/20', 'text-red-200');
        
        if (response.ok) {
          form.reset();
          formMessage.textContent = 'Message sent successfully! We will contact you soon.';
          formMessage.classList.add('bg-green-500/20', 'text-green-200', 'border', 'border-green-500/30');
        } else {
          throw new Error('Network response was not ok');
        }
      } catch (error) {
        console.error('Error:', error);
        formMessage.textContent = 'There was an error sending your message. Please try again later.';
        formMessage.classList.add('bg-red-500/20', 'text-red-200', 'border', 'border-red-500/30');
      } finally {
        btnText.textContent = 'Send Message';
        setTimeout(() => {
          formMessage.classList.add('hidden');
          formMessage.className = 'hidden mt-4 p-4 rounded-xl text-center font-medium font-body transition-all';
        }, 6000);
      }
    });
  }

  // Animations
  document.addEventListener("DOMContentLoaded", () => {
    gsap.fromTo('.gs-form-bg', 
      { yPercent: 20, scale: 1.1 },
      { scrollTrigger: { trigger: '#contact', start: "top bottom", scrub: true }, yPercent: 0, scale: 1, ease: "none" }
    );

    gsap.fromTo('.gs-form-title', 
      { y: 30, opacity: 0 },
      { scrollTrigger: { trigger: '.gs-form-title', start: "top 85%" }, y: 0, opacity: 1, duration: 1, clearProps: "all" }
    );

    gsap.fromTo('.gs-form-card', 
      { y: 60, opacity: 0 },
      { scrollTrigger: { trigger: '.gs-form-title', start: "top 60%" }, y: 0, opacity: 1, duration: 1, ease: "back.out(1)", clearProps: "all" }
    );
  });
</script>
