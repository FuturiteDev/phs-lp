---
import specImg1 from '../../assets/images/AGS-04-IM207.webp'
import specImg2 from '../../assets/images/AGS-04-IM215.webp'
import specImg3 from '../../assets/images/AGS-04-IM211.webp'
import specImg4 from '../../assets/images/AGS-04-IM205.webp'
---

<section class="py-24 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16 gs-spec-title">
            <h2 class="text-4xl md:text-5xl font-extrabold text-dark">Especificaciones Técnicas</h2>
        </div>

        <div class="flex flex-col lg:flex-row gap-16 items-center">
            <!-- Galería -->
            <div class="w-full lg:w-1/2 gs-spec-img">
                <div class="swiper specsSwiper w-full h-[450px] md:h-[550px] rounded-3xl shadow-2xl relative">
                    <div class="swiper-wrapper">
                        <div class="swiper-slide">
                            <img src={specImg1.src} alt="Especificación 1" class="w-full h-full object-cover" />
                            <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent"></div>
                        </div>
                        <div class="swiper-slide">
                            <img src={specImg2.src} alt="Especificación 2" class="w-full h-full object-cover" />
                            <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent"></div>
                        </div>
                        <div class="swiper-slide">
                            <img src={specImg3.src} alt="Especificación 3" class="w-full h-full object-cover" />
                            <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent"></div>
                        </div>
                        <div class="swiper-slide">
                            <img src={specImg4.src} alt="Especificación 4" class="w-full h-full object-cover" />
                            <div class="absolute inset-0 bg-gradient-to-t from-dark/60 to-transparent"></div>
                        </div>
                    </div>
                    <div class="swiper-pagination"></div>
                </div>
            </div>

            <!-- Detalles -->
            <div class="w-full lg:w-1/2 gs-spec-text">
                <ul class="flex flex-col gap-4">
                    <li class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
                        <svg xmlns="http://www.w3.org/2000/svg" class="flex-none h-7 w-7 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <p class="text-gray-800 text-lg">
                            <strong class="font-bold text-primary block mb-1">Ubicación:</strong>
                            ATC Logistics Park VI (Aguascalientes, Aguascalientes).
                        </p>
                    </li>
                    <li class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
                        <svg xmlns="http://www.w3.org/2000/svg" class="flex-none h-7 w-7 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
                        </svg>
                        <p class="text-gray-800 text-lg">
                            <strong class="font-bold text-primary block mb-1">Superficie:</strong>
                            Desde 1,500 m² hasta 13,700 m².
                        </p>
                    </li>
                    <li class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
                        <svg xmlns="http://www.w3.org/2000/svg" class="flex-none h-7 w-7 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                        </svg>
                        <p class="text-gray-800 text-lg">
                            <strong class="font-bold text-primary block mb-1">Tipo de Construcción:</strong>
                            Bodega industrial clase A Aguascalientes.
                        </p>
                    </li>
                    <li class="flex items-start gap-4 p-4 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
                        <svg xmlns="http://www.w3.org/2000/svg" class="flex-none h-7 w-7 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <p class="text-gray-800 text-lg">
                            <strong class="font-bold text-primary block mb-1">Estado del Proyecto:</strong>
                            En proceso de construcción / Fase de preventa con entrega planificada.
                        </p>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<script>
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'
    import Swiper from 'swiper'
    import { Pagination, Autoplay, EffectFade } from 'swiper/modules'
    import 'swiper/css'
    import 'swiper/css/pagination'
    import 'swiper/css/effect-fade'

    gsap.registerPlugin(ScrollTrigger)

    document.addEventListener('DOMContentLoaded', () => {
        new Swiper('.specsSwiper', {
            modules: [Pagination, Autoplay, EffectFade],
            effect: 'fade',
            fadeEffect: { crossFade: true },
            autoplay: { delay: 4000, disableOnInteraction: false },
            pagination: { el: '.swiper-pagination', clickable: true },
            loop: true,
        })

        gsap.from('.gs-spec-title', { scrollTrigger: { trigger: '.gs-spec-title', start: 'top 80%' }, y: 30, opacity: 0, duration: 1, ease: 'power3.out' })
        gsap.from('.gs-spec-img', { scrollTrigger: { trigger: '.gs-spec-img', start: 'top 80%' }, x: -50, opacity: 0, duration: 1, ease: 'power3.out' })
        gsap.from('.gs-spec-text', { scrollTrigger: { trigger: '.gs-spec-text', start: 'top 80%' }, x: 50, opacity: 0, duration: 1, ease: 'power3.out' })
    })
</script>
