---
// Componente de contacto
---

<section id="contact" class="flex overflow-hidden">
    <!-- Layout dividido -->
    <div class="flex flex-col lg:flex-row w-full min-h-screen">
        <!-- Izquierda: Mapa -->
        <div class="w-full lg:w-1/2 h-[400px] lg:h-auto lg:min-h-full relative block">
            <iframe 
                src="https://www.google.com/maps/embed?pb=!1m16!1m12!1m3!1d1541.0826641630463!2d-102.29733936693023!3d21.74268738143636!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!2m1!1sParque%20Industrial%20Douki%20Seisan%20Park%2020340%20Ags.%2021.742664%2C%20-102.297171!5e1!3m2!1ses!2smx!4v1782341236162!5m2!1ses!2smx"
                class="absolute inset-0 w-full h-full border-0" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>

        <!-- Derecha: Formulario -->
        <div class="w-full lg:w-1/2 bg-primary flex flex-col justify-center px-8 md:px-16 py-16">
            <div class="gs-form-card mb-8">
                <h3 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-dark leading-tight">Hablemos de tu<br />Proyecto Industrial.</h3>
            </div>

            <form id="contactFormAGS" class="flex flex-col gap-5 gs-form-card">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="flex flex-col">
                        <label for="nombre_ags" class="text-dark text-sm font-semibold mb-1">Nombre completo</label>
                        <input type="text" id="nombre_ags" name="nombre" class="bg-transparent border-b-2 border-dark/40 px-0 py-2 text-dark placeholder-dark/40 focus:outline-none focus:border-dark transition-all font-body" placeholder="Juan Pérez" required />
                    </div>
                    <div class="flex flex-col">
                        <label for="telefono_ags" class="text-dark text-sm font-semibold mb-1">Teléfono</label>
                        <input type="tel" id="telefono_ags" name="telefono" class="bg-transparent border-b-2 border-dark/40 px-0 py-2 text-dark placeholder-dark/40 focus:outline-none focus:border-dark transition-all font-body" placeholder="(555) 000-0000" required />
                    </div>
                </div>

                <div class="flex flex-col">
                    <label for="correo_ags" class="text-dark text-sm font-semibold mb-1">Correo electrónico</label>
                    <input type="email" id="correo_ags" name="correo" class="bg-transparent border-b-2 border-dark/40 px-0 py-2 text-dark placeholder-dark/40 focus:outline-none focus:border-dark transition-all font-body" placeholder="juan@empresa.com" required />
                </div>

                <div class="flex flex-col">
                    <label for="mensaje_ags" class="text-dark text-sm font-semibold mb-1">Mensaje</label>
                    <textarea id="mensaje_ags" name="mensaje" rows="3" class="bg-transparent border-b-2 border-dark/40 px-0 py-2 text-dark placeholder-dark/40 focus:outline-none focus:border-dark transition-all font-body resize-none" placeholder="Cuéntanos sobre tu proyecto..." required></textarea>
                </div>

                <button type="submit" class="mt-4 px-8 py-4 bg-white text-dark font-bold text-lg rounded-lg uppercase tracking-wider hover:bg-dark hover:text-white transition-all duration-300 shadow-lg transform hover:-translate-y-1">
                    <span id="btnTextAGS">Enviar</span>
                </button>

                <div id="formMessageAGS" class="hidden mt-2 p-4 rounded-xl text-center font-medium font-body transition-all"></div>
            </form>
        </div>
    </div>
</section>

<script>
    import { gsap } from 'gsap'
    import { ScrollTrigger } from 'gsap/ScrollTrigger'

    gsap.registerPlugin(ScrollTrigger)

    const form = document.getElementById('contactFormAGS') as HTMLFormElement
    const btnText = document.getElementById('btnTextAGS')
    const formMessage = document.getElementById('formMessageAGS')

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault()
            if (!btnText || !formMessage) return
            const formData = new FormData(form)
            const data = {
                nombre: formData.get('nombre'),
                telefono: formData.get('telefono'),
                correo: formData.get('correo'),
                mensaje: formData.get('mensaje'),
                origen: 'https://phs-desarrollos.com/naves-industriales/ags/',
            }

            try {
                btnText.textContent = 'Enviando...'
                const response = await fetch('https://n8n.ongoing.mx/webhook/c858672b-7cff-40e0-bc29-f03b41febad7', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        phs: 'Huo0lpaw.',
                    },
                    body: JSON.stringify(data),
                })
                formMessage.classList.remove('hidden', 'bg-red-500/20', 'text-red-200')
                if (response.ok) {
                    form.reset()
                    const base = import.meta.env.BASE_URL || ''
                    const baseUrl = base.endsWith('/') ? base.slice(0, -1) : base
                    window.location.href = `${baseUrl}/ags/gracias/`
                } else {
                    throw new Error('Error en la respuesta')
                }
            } catch (error) {
                formMessage.textContent = 'Hubo un error al enviar tu mensaje. Intenta de nuevo más tarde.'
                formMessage.classList.add('bg-red-500/20', 'text-red-200', 'border', 'border-red-500/30')
            } finally {
                btnText.textContent = 'Enviar'
                setTimeout(() => {
                    formMessage.classList.add('hidden')
                    formMessage.className = 'hidden mt-2 p-4 rounded-xl text-center font-medium font-body transition-all'
                }, 6000)
            }
        })
    }

    document.addEventListener('DOMContentLoaded', () => {
        gsap.fromTo('.gs-form-title', { y: 30, opacity: 0 }, { scrollTrigger: { trigger: '.gs-form-title', start: 'top 85%' }, y: 0, opacity: 1, duration: 1, clearProps: 'all' })
        gsap.fromTo('.gs-form-card', { y: 60, opacity: 0 }, { scrollTrigger: { trigger: '.gs-form-title', start: 'top 60%' }, y: 0, opacity: 1, duration: 1, ease: 'back.out(1)', clearProps: 'all' })
    })
</script>
