---
import phsLogo from '../assets/images/logotipo-phs-EN-BLANCO.png';
---

<header class="relative w-full h-[80vh] min-h-[600px] flex flex-col justify-between overflow-hidden bg-dark">
  <!-- GSAP Background Element -->
  <div class="absolute inset-0 z-0 opacity-40">
    <img 
      src={(await import('../assets/images/exterior_8.jpeg')).default.src} 
      alt="Hero Background" 
      class="w-full h-full object-cover hero-bg-img"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/80 to-transparent"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pt-8">
    <img src={phsLogo.src} alt="PHS Logistics" class="h-12 md:h-16 w-auto object-contain opacity-90" />
  </div>
  
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 pb-20 flex flex-col md:flex-row items-center md:items-end justify-between gap-12">
    <div class="flex-1 w-full text-center md:text-left">
      <h1 class="hero-title text-primary text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tight">
        Warehouse and<br/>Industrial Park<br/>Leasing in Nuevo León
      </h1>
    </div>
    
    <div class="flex-none max-w-md flex flex-col items-center md:items-end text-center md:text-right">
      <p class="hero-desc text-white text-lg font-light mb-8">
        Find the ideal operations hub for your business in our logistics parks in Nuevo León.
      </p>
      <a href="#contact" class="hero-btn inline-block w-full md:w-auto px-8 py-4 bg-white text-dark font-bold uppercase tracking-wide transition-all hover:bg-primary hover:scale-105 shadow-xl">
        Contact us now
      </a>
    </div>
  </div>
</header>

<script>
  import { gsap } from 'gsap';
  
  // Animation on load
  document.addEventListener("DOMContentLoaded", () => {
    const tl = gsap.timeline();
    
    tl.fromTo('.hero-bg-img', 
      { scale: 1.1, opacity: 0 },
      { scale: 1, opacity: 1, duration: 1.5, ease: "power2.out" }
    )
    .fromTo('.hero-title',
      { y: 50, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, ease: "power3.out" },
      "-=1"
    )
    .fromTo('.hero-desc',
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, ease: "power3.out" },
      "-=0.6"
    )
    .fromTo('.hero-btn',
      { scale: 0.9, opacity: 0 },
      { scale: 1, opacity: 1, duration: 0.5, ease: "back.out(1.7)" },
      "-=0.4"
    );
  });
</script>
