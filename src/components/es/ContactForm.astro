---
import formImg from '../../assets/images/interior_3.jpeg';
---

<section id="contact" class="flex overflow-hidden">

  <!-- Layout dividido -->
  <div class="flex flex-col lg:flex-row w-full min-h-screen">

    <!-- Izquierda: Imagen -->
    <div class="hidden lg:flex w-1/2 bg-primary relative overflow-hidden">
      <img src={formImg.src} alt="Interior Industrial" class="gs-form-bg absolute inset-0 w-full h-full object-cover" />
    </div>

    <!-- Derecha: Formulario -->
    <div class="w-full lg:w-1/2 bg-primary flex flex-col justify-center px-8 md:px-16 py-16">
      <div class="gs-form-card mb-8">
        <h3 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-dark leading-tight">Hablemos de tu<br/>proyecto industrial.</h3>
      </div>

      <form id="contactFormES" class="flex flex-col gap-5 gs-form-card">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="flex flex-col">
            <label for="nombre_es" class="text-dark text-sm font-semibold mb-1">Nombre completo</label>
            <input type="text" id="nombre_es" name="nombre" class="bg-transparent border-b-2 border-dark/40 px-0 py-2 text-dark placeholder-dark/40 focus:outline-none focus:border-dark transition-all font-body" placeholder="Juan Pérez" required>
          </div>
          <div class="flex flex-col">
            <label for="telefono_es" class="text-dark text-sm font-semibold mb-1">Teléfono</label>
            <input type="tel" id="telefono_es" name="telefono" class="bg-transparent border-b-2 border-dark/40 px-0 py-2 text-dark placeholder-dark/40 focus:outline-none focus:border-dark transition-all font-body" placeholder="(555) 000-0000" required>
          </div>
        </div>

        <div class="flex flex-col">
          <label for="correo_es" class="text-dark text-sm font-semibold mb-1">Correo electrónico</label>
          <input type="email" id="correo_es" name="correo" class="bg-transparent border-b-2 border-dark/40 px-0 py-2 text-dark placeholder-dark/40 focus:outline-none focus:border-dark transition-all font-body" placeholder="juan@empresa.com" required>
        </div>

        <div class="flex flex-col">
          <label for="mensaje_es" class="text-dark text-sm font-semibold mb-1">Mensaje</label>
          <textarea id="mensaje_es" name="mensaje" rows="3" class="bg-transparent border-b-2 border-dark/40 px-0 py-2 text-dark placeholder-dark/40 focus:outline-none focus:border-dark transition-all font-body resize-none" placeholder="Cuéntanos sobre tu proyecto..." required></textarea>
        </div>

        <button type="submit" class="mt-4 px-8 py-4 bg-white text-dark font-bold text-lg rounded-lg uppercase tracking-wider hover:bg-dark hover:text-white transition-all duration-300 shadow-lg transform hover:-translate-y-1">
          <span id="btnTextES">Enviar</span>
        </button>

        <div id="formMessageES" class="hidden mt-2 p-4 rounded-xl text-center font-medium font-body transition-all"></div>
      </form>
    </div>

  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const form = document.getElementById('contactFormES') as HTMLFormElement;
  const btnText = document.getElementById('btnTextES');
  const formMessage = document.getElementById('formMessageES');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btnText || !formMessage) return;
      const formData = new FormData(form);
      const data = {
        nombre: formData.get('nombre'),
        telefono: formData.get('telefono'),
        correo: formData.get('correo'),
        mensaje: formData.get('mensaje'),
        origen: 'https://phs-desarrollos.com/naves-industriales'
      };

      try {
        btnText.textContent = 'Enviando...';
        const response = await fetch('https://n8n.ongoing.mx/webhook/c858672b-7cff-40e0-bc29-f03b41febad7', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'phs': 'Huo0lpaw.'
          },
          body: JSON.stringify(data)
        });
        formMessage.classList.remove('hidden', 'bg-red-500/20', 'text-red-200');
        if (response.ok) {
          form.reset();
          formMessage.textContent = '¡Mensaje enviado! Nos pondremos en contacto pronto.';
          formMessage.classList.add('bg-green-500/20', 'text-green-200', 'border', 'border-green-500/30');
        } else {
          throw new Error('Error en la respuesta');
        }
      } catch (error) {
        formMessage.textContent = 'Hubo un error al enviar tu mensaje. Intenta de nuevo más tarde.';
        formMessage.classList.add('bg-red-500/20', 'text-red-200', 'border', 'border-red-500/30');
      } finally {
        btnText.textContent = 'Enviar';
        setTimeout(() => {
          formMessage.classList.add('hidden');
          formMessage.className = 'hidden mt-2 p-4 rounded-xl text-center font-medium font-body transition-all';
        }, 6000);
      }
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    gsap.fromTo('.gs-form-title', { y: 30, opacity: 0 }, { scrollTrigger: { trigger: '.gs-form-title', start: "top 85%" }, y: 0, opacity: 1, duration: 1, clearProps: "all" });
    gsap.fromTo('.gs-form-card', { y: 60, opacity: 0 }, { scrollTrigger: { trigger: '.gs-form-title', start: "top 60%" }, y: 0, opacity: 1, duration: 1, ease: "back.out(1)", clearProps: "all" });
  });
</script>
