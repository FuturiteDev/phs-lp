---
---

<section class="bg-gray-100 py-24 relative">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    
    <!-- Top Big Showcase -->
    <div class="bg-primary rounded-3xl shadow-xl overflow-hidden flex flex-col md:flex-row mb-12 gs-spaces-card group">
      <div class="w-full md:w-1/2 h-[400px] md:h-[500px]">
        <iframe 
          src="https://maps.google.com/maps?q=25.9546111,-100.26775&z=15&output=embed" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
      <div class="w-full md:w-1/2 p-10 flex flex-col justify-center items-center text-center bg-primary">
        <h3 class="text-3xl font-extrabold text-dark mb-2">ATC Logistics Park III</h3>
        <p class="text-gray-600 font-medium mb-8 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-dark" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
          Apodaca, Nuevo León.
        </p>
        <a href="#contact" class="inline-block px-10 py-4 bg-dark text-white font-bold rounded-lg w-full uppercase transition-all duration-300 hover:bg-white hover:text-dark hover:-translate-y-1 shadow-lg">
          Get a Quote for Your Industrial Space
        </a>
      </div>
    </div>
    
    <!-- Bottom Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Card I -->
      <div class="bg-primary rounded-3xl shadow-sm hover:shadow-xl transition-shadow duration-300 overflow-hidden group gs-spaces-mini">
        <div class="h-48 overflow-hidden relative">
          <iframe 
            src="https://maps.google.com/maps?q=25.9546111,-100.26775&z=14&output=embed" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
        <div class="p-6 text-center">
          <h4 class="text-xl font-bold text-dark mb-1">ATC Logistics Park I</h4>
          <p class="text-gray-500 text-sm font-medium flex items-center justify-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-dark" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
            Salinas Victoria, Nuevo León.
          </p>
        </div>
      </div>
      
      <!-- Card II -->
      <div class="bg-primary rounded-3xl shadow-sm hover:shadow-xl transition-shadow duration-300 overflow-hidden group gs-spaces-mini">
        <div class="h-48 overflow-hidden relative">
          <iframe 
            src="https://maps.google.com/maps?q=25.9553333,-100.2738333&z=14&output=embed" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
        <div class="p-6 text-center">
          <h4 class="text-xl font-bold text-dark mb-1">ATC Logistics Park II</h4>
          <p class="text-gray-500 text-sm font-medium flex items-center justify-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-dark" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
            Salinas Victoria, Nuevo León.
          </p>
        </div>
      </div>

      <!-- Card IV -->
      <div class="bg-primary rounded-3xl shadow-sm hover:shadow-xl transition-shadow duration-300 overflow-hidden group gs-spaces-mini">
        <div class="h-48 overflow-hidden relative">
          <iframe 
            src="https://maps.google.com/maps?q=25.8088333,-100.0915278&z=14&output=embed" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
        <div class="p-6 text-center">
          <h4 class="text-xl font-bold text-dark mb-1">ATC Logistics Park IV</h4>
          <p class="text-gray-500 text-sm font-medium flex items-center justify-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-dark" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
            Pesquería, Nuevo León.
          </p>
        </div>
      </div>

      <!-- Card V -->
      <div class="bg-primary rounded-3xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden group gs-spaces-mini">
        <div class="h-48 overflow-hidden relative">
          <iframe 
            src="https://maps.google.com/maps?q=25.7438889,-100.0713333&z=14&output=embed" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
        <div class="p-6 text-center">
          <h4 class="text-xl font-bold text-dark mb-1">ATC Logistics Park V</h4>
          <p class="text-gray-500 text-sm font-medium flex items-center justify-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-dark" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
            Pesquería, Nuevo León.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    // GSAP
    gsap.fromTo('.gs-spaces-card', 
      { y: 50, opacity: 0 },
      { scrollTrigger: { trigger: '.gs-spaces-card', start: "top 80%" }, y: 0, opacity: 1, duration: 1, ease: "power3.out" }
    );

    gsap.fromTo('.gs-spaces-mini', 
      { y: 40, opacity: 0 },
      { scrollTrigger: { trigger: '.gs-spaces-card', start: "top 20%" }, y: 0, opacity: 1, stagger: 0.1, duration: 0.8, ease: "back.out(1.2)", clearProps: "all" }
    );
  });
</script>
