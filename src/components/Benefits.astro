---
---

<section class="py-24 bg-[#E5E7EB] relative">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 bento-title-anim">
      <h2 class="text-4xl md:text-5xl font-extrabold text-dark inline-block relative">
        Key Benefits
        <span class="absolute -bottom-4 left-1/2 transform -translate-x-1/2 w-24 h-1 bg-primary"></span>
      </h2>
    </div>
    
    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Card 1: Wide (2 cols) - Dark -->
      <div class="bento-card-anim md:col-span-2">
        <div class="relative overflow-hidden rounded-3xl bg-[#212121] p-10 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center h-full min-h-[220px]">
          <h3 class="text-3xl font-extrabold mb-3 text-[#FFCB42]">Immediate Operation</h3>
          <p class="text-gray-300 text-lg leading-relaxed">Your leased industrial warehouse is ready for use with total utility feasibility (Power/CFE, Water, and Fiber Optics) so you don't lose a single day of production.</p>
        </div>
      </div>

      <!-- Card 2: Square - Yellow -->
      <div class="bento-card-anim">
        <div class="relative overflow-hidden rounded-3xl bg-[#FFCB42] p-8 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center h-full min-h-[220px]">
          <h3 class="text-2xl font-extrabold mb-3 text-[#212121]">Cutting-Edge Infrastructure</h3>
          <p class="text-[#212121]/80 text-lg leading-relaxed">Built with Tilt-Up concrete walls and KR-18 standing seam roofing to guarantee durability and structural safety.</p>
        </div>
      </div>

      <!-- Card 3: Square - White -->
      <div class="bento-card-anim">
        <div class="relative overflow-hidden rounded-3xl bg-white p-8 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center h-full min-h-[220px]">
          <h3 class="text-2xl font-extrabold mb-3 text-[#212121]">Logistics Efficiency</h3>
          <p class="text-gray-600 text-lg leading-relaxed">Strategically located in Nuevo León to optimize transit times and reduce operating costs.</p>
        </div>
      </div>

      <!-- Card 4: Wide (2 cols) - White -->
      <div class="bento-card-anim md:col-span-2">
        <div class="relative overflow-hidden rounded-3xl bg-white p-10 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center h-full min-h-[220px]">
          <h3 class="text-3xl font-extrabold mb-3 text-[#212121]">Security &amp; Control</h3>
          <p class="text-gray-600 text-lg leading-relaxed">Master-planned industrial parks with professional infrastructure, controlled access, and 24/7 monitoring.</p>
        </div>
      </div>

      <!-- Card 5: Square - Dark -->
      <div class="bento-card-anim">
        <div class="relative overflow-hidden rounded-3xl bg-[#212121] p-8 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center h-full min-h-[220px]">
          <h3 class="text-2xl font-extrabold mb-3 text-[#FFCB42]">Real Sustainability</h3>
          <p class="text-gray-300 text-lg leading-relaxed">LEED Certification, energy-efficient LED lighting and on-site water treatment plants.</p>
        </div>
      </div>

      <!-- Card 6: 2 cols - Yellow accent border -->
      <div class="bento-card-anim md:col-span-2">
        <div class="relative overflow-hidden rounded-3xl bg-white border-l-8 border-[#FFCB42] p-10 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center h-full min-h-[220px]">
          <h3 class="text-2xl font-extrabold mb-3 text-[#212121]">Access to Talent</h3>
          <p class="text-gray-600 text-lg leading-relaxed">Facilities situated in high-density labor zones within Nuevo León to ensure access to a qualified workforce.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  
  gsap.registerPlugin(ScrollTrigger);
  
  document.addEventListener("DOMContentLoaded", () => {
    gsap.fromTo('.bento-title-anim', 
      { y: 40, opacity: 0 },
      {
        scrollTrigger: { trigger: '.bento-title-anim', start: "top 80%" },
        y: 0, opacity: 1, duration: 0.8
      }
    );

    gsap.fromTo('.bento-card-anim', 
      { y: 60, opacity: 0 },
      {
        scrollTrigger: { trigger: '.bento-title-anim', start: "top 60%" },
        y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: "back.out(1.2)", clearProps: "all"
      }
    );
    
    gsap.fromTo('.GSAP-btn', 
      { scale: 0.8, opacity: 0 },
      {
        scrollTrigger: { trigger: '.GSAP-btn', start: "top 95%" },
        scale: 1, opacity: 1, duration: 0.8, ease: "elastic.out(1, 0.5)", clearProps: "all"
      }
    );
  });
</script>
