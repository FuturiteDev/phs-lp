---
import bgImg1 from '../assets/images/interior_1.jpeg';
import bgImg2 from '../assets/images/interior_4.jpeg';
---

<section class="py-24 bg-[#E5E7EB] relative"> <!-- Explicit standard gray background -->
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 bento-title-anim">
      <h2 class="text-4xl md:text-5xl font-extrabold text-dark inline-block relative">
        Key Benefits
        <span class="absolute -bottom-4 left-1/2 transform -translate-x-1/2 w-24 h-1 bg-primary"></span>
      </h2>
    </div>
    
    <!-- Bento Grid Setup -->
    <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-3 gap-6 auto-rows-fr">
      
      <!-- Card 1: Large (spans 2 cols) with image bg -->
      <div class="bento-card-anim md:col-span-2 md:row-span-2">
        <div class="relative overflow-hidden rounded-3xl bg-white shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-end text-white !p-0 h-full min-h-[300px]">
          <img src={bgImg1.src} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 hover:scale-110" alt="Immediate Operation" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#212121] via-[#212121]/70 to-transparent"></div>
          <div class="relative z-10 p-8 pt-32">
            <h3 class="text-2xl font-bold mb-3 text-[#FFCB42]">Immediate Operation</h3>
            <p class="text-white text-lg">Ready-to-use spaces with full utility access (light, power, water, and fiber optics) so you don't lose a single day of production.</p>
          </div>
        </div>
      </div>

      <!-- Card 2: Square Standard -->
      <div class="bento-card-anim">
        <div class="relative overflow-hidden rounded-3xl bg-white p-8 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center h-full">
          <h3 class="text-2xl font-bold mb-3 text-[#212121]">State of the Art Infrastructure</h3>
          <p class="text-gray-600 text-lg">Construction including 10+ tilt-up walling that guarantee durability, advanced clear height, and technical specifications for your business.</p>
        </div>
      </div>

      <!-- Card 3: Square Primary -->
      <div class="bento-card-anim">
        <div class="relative overflow-hidden rounded-3xl p-8 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center bg-[#FFCB42] text-[#212121] h-full">
          <h3 class="text-2xl font-bold mb-3 text-[#212121]">Logistical Efficiency</h3>
          <p class="text-[#212121]/80 font-medium text-lg">Strategically located throughout Nuevo León, with excellent air connectivity to optimize transit times and operational costs.</p>
        </div>
      </div>

      <!-- Card 4: Standard -->
      <div class="bento-card-anim">
        <div class="relative overflow-hidden rounded-3xl bg-white p-8 shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center h-full">
          <h3 class="text-2xl font-bold mb-3 text-[#212121]">Security and Control</h3>
          <p class="text-gray-600 text-lg">Consolidated industrial environment with master-planned infrastructure, controlled access, and 24/7 monitoring.</p>
        </div>
      </div>

      <!-- Card 5: Large Row (spans 2 cols) -->
      <div class="bento-card-anim md:col-span-2">
        <div class="relative overflow-hidden rounded-3xl bg-white shadow-md transition-shadow duration-300 hover:shadow-xl flex flex-col justify-center !p-0 h-full">
          <img src={bgImg2.src} class="absolute inset-0 w-full h-full object-cover opacity-30 grayscale mix-blend-overlay transition-transform duration-700 hover:scale-110" alt="Sustainability" />
          <div class="absolute inset-0 bg-[#212121]/90"></div>
          <div class="relative z-10 p-8 flex flex-col md:flex-row gap-8 items-center">
            <div class="flex-1">
              <h3 class="text-2xl font-bold mb-3 text-white">Sustainability</h3>
              <p class="text-gray-300 text-lg">Projects designed with LEED certification, LED lighting, and a treatment water system.</p>
            </div>
            <div class="flex-1 border-t md:border-t-0 md:border-l border-white/20 pt-6 md:pt-0 md:pl-8">
              <h3 class="text-2xl font-bold mb-3 text-white">Access to Talent</h3>
              <p class="text-gray-300 text-lg">Strategic locations in high-density labor areas to ensure the recruitment of qualified personnel for your workforce.</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="mt-16 flex justify-center GSAP-btn">
      <a href="#contact" class="inline-block px-12 py-4 bg-dark text-white font-bold text-lg rounded-full uppercase tracking-wider transition-all duration-300 hover:bg-primary hover:text-dark hover:-translate-y-1 shadow-xl hover:shadow-primary/30">
        Contact us now
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  
  gsap.registerPlugin(ScrollTrigger);
  
  document.addEventListener("DOMContentLoaded", () => {
    gsap.fromTo('.bento-title-anim', 
      { y: 40, opacity: 0 },
      {
        scrollTrigger: { trigger: '.bento-title-anim', start: "top 80%" },
        y: 0, opacity: 1, duration: 0.8
      }
    );

    gsap.fromTo('.bento-card-anim', 
      { y: 60, opacity: 0 },
      {
        scrollTrigger: { trigger: '.bento-title-anim', start: "top 60%" },
        y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: "back.out(1.2)", clearProps: "all"
      }
    );
    
    gsap.fromTo('.GSAP-btn', 
      { scale: 0.8, opacity: 0 },
      {
        scrollTrigger: { trigger: '.GSAP-btn', start: "top 95%" },
        scale: 1, opacity: 1, duration: 0.8, ease: "elastic.out(1, 0.5)", clearProps: "all"
      }
    );
  });
</script>
